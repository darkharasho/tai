{
  "name": "tai",
  "version": "1.10.1",
  "description": "An AI-native terminal that understands what you're doing.",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "predist": "cd daemon && make all",
    "dist": "vite build && electron-builder --linux AppImage",
    "predist:win": "cd daemon && make all",
    "dist:win": "vite build && electron-builder --win",
    "predist:mac": "cd daemon && make all",
    "dist:mac": "vite build && electron-builder --mac dmg zip",
    "readme:screenshots": "npm run build && node scripts/take-screenshots.mjs",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts"
  },
  "keywords": [],
  "author": "darkharasho",
  "license": "ISC",
  "build": {
    "appId": "com.tai.app",
    "productName": "tai",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "public/img/tai.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/img/tai.png",
      "artifactName": "tai-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "public/img/tai.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "publish": {
      "provider": "github",
      "owner": "darkharasho",
      "repo": "tai"
    },
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/node-termios/**/*"
    ],
    "extraResources": [
      {
        "from": "daemon/dist/",
        "to": "daemon/dist/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/shell-integration",
        "to": "shell-integration",
        "filter": [
          "**/*",
          "**/.*"
        ]
      }
    ]
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.1.0",
    "node-termios": "^0.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shell-quote": "^1.8.3",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@xterm/headless": "^6.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  }
}
